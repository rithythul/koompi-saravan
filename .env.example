# Core generation
GEMINI_API_KEY=
GOOGLE_MEDIA_OUTPUT_DIR=./var/outputs
GOOGLE_MEDIA_DRY_RUN=true
GOOGLE_MEDIA_KILL_SWITCH=false
# Optional public URL that serves files from GOOGLE_MEDIA_OUTPUT_DIR
GOOGLE_MEDIA_PUBLIC_BASE_URL=

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional override
INSTAGRAM_API_BASE_URL=https://graph.facebook.com/v23.0

# TikTok API
TIKTOK_ACCESS_TOKEN=
TIKTOK_CREATOR_ID=
# Optional override
TIKTOK_API_BASE_URL=https://open.tiktokapis.com/v2
